table financials
	lineageTag: 6a224f03-20ba-41fd-9b1a-513462d88447

	measure 'Total Sales' = SUM(financials[Sales])
		formatString: $ #,##0

		annotation GenerateTimeIntelligence = true

	measure 'Total Profit' = SUM(financials[Profit])
		formatString: $ #,##0

		annotation GenerateTimeIntelligence = true

	measure 'Total Units Sold' = SUM(financials[Units Sold])
		formatString: #,##0

	column Segment
		dataType: string
		lineageTag: ea86d56d-be27-4aed-93dd-fabb4f67e278
		summarizeBy: none
		sourceColumn: Segment

		annotation SummarizationSetBy = Automatic

	column Country
		dataType: string
		lineageTag: d98d2519-876d-479d-9d4f-c55e99410102
		summarizeBy: none
		sourceColumn: Country

		annotation SummarizationSetBy = Automatic

	column Product
		dataType: string
		lineageTag: 81572d6b-2a24-4338-b49b-e99fa7add7c8
		summarizeBy: none
